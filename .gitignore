# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/
*.egg-info/
dist/
build/

# Frontend (Vite + Vue 3)
# 构建产物由 CI / Docker builder 阶段产出,不进 git
node_modules/
frontend/dist/
static/dist/

# Local data & cache (must NOT be committed)
local_ehr_db/
local_ehr_uploads/
local_backups/
*.sqlite3
*.db

# Environment variables (may contain secrets)
.env
.env.*
!.env.example

# IDE
.vscode/
.idea/
.DS_Store

# Logs
*.log
nohup.out

# Model weights (download at runtime)
# 只忽略仓库根目录的 models/ 和 weights/（用于存放本地大模型权重）
# 不能直接写 `models/` —— 那样连 app/models/ 里的 Pydantic Schemas 也会被吞掉
/models/
/weights/
*.onnx
*.gguf

# OS
Thumbs.db
ehthumbs.db
Desktop.ini


# Edge sync agent (PR#7) - 离线 / 已发送 payload 都不进 git
local_sync_outbox/
